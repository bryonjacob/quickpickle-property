{
  "name": "quickpickle-property",
  "version": "0.1.0",
  "type": "module",
  "description": "Property-based testing plugin for QuickPickle — express universal invariants in standard Gherkin",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:conformance": "vitest run --config vitest.conformance.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "fast-check": "^3.0.0",
    "quickpickle": "^1.0.0",
    "vitest": "^1.0.0 || >=2.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^3.0.0",
    "pixelmatch": "^7.1.0",
    "prettier": "^3.0.0",
    "quickpickle": "^1.11.0",
    "specdrive": "^0.1.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "quickpickle",
    "property-based-testing",
    "gherkin",
    "fast-check",
    "bdd",
    "pbt",
    "hypothesis",
    "invariant"
  ],
  "author": "Quickpickle Property Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bryonjacob/quickpickle-property.git"
  },
  "homepage": "https://github.com/bryonjacob/quickpickle-property",
  "bugs": {
    "url": "https://github.com/bryonjacob/quickpickle-property/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
